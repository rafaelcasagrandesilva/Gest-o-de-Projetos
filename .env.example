ENV=local
APP_NAME=SGP Backend
API_V1_PREFIX=/api/v1

# Security
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# true = imprime token/payload no console (apenas depuração local)
AUTH_DEBUG=false
# Produção: domínios do frontend, separados por vírgula (obrigatório se ENV=production)
# CORS_ORIGINS=https://app.seudominio.com
# E-mails com privilégios de superusuário operacional (opcional; substitui lista padrão do código)
# APP_SUPERUSER_EMAILS=admin@empresa.com

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sgp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sgp
# Pool (asyncpg) — ajuste conforme carga
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=15
# DB_POOL_RECYCLE_SECONDS=1800

# Uploads (PDFs de NF) — em produção use volume persistente no mesmo caminho
# RECEIVABLE_UPLOAD_DIR=/data/receivable_uploads
